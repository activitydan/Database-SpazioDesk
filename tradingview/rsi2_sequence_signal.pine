//@version=6
// =============================================================================
// RSI(2) Sequence Signal - Long / Short  (pattern 1-2-3 supporto/resistenza)
// -----------------------------------------------------------------------------
// La sequenza sull'RSI(2) e' composta da 3 movimenti consecutivi attorno al 50:
//
//   BUY (1-2-3):
//     1) l'RSI da sotto 50 sale sopra 50 e forma un PICCO      -> punto 1 (resistenza)
//     2) rientra sotto 50 SENZA rompere il minimo di partenza  -> punto 2 (supporto)
//     3) torna sopra 50 SUPERANDO il picco del punto 1         -> punto 3 => LONG
//
//   SELL: esatto speculare (invertito attorno al 50).
//
// Filtri:
//   - EMA: la media deve stare TUTTA FUORI dal corpo (open-close) della candela.
//          LONG solo con EMA sotto il corpo, SHORT solo con EMA sopra il corpo.
//          Se l'EMA entra nel corpo -> nessun segnale. Puo' toccare le ombre.
//   - ADX : opera solo quando ADX e' FUORI dalla banda (sotto adxLow o sopra adxHigh).
//
// NOTA: scritto SENZA blocchi indentati (solo assegnazioni su singola riga)
// per essere incollabile anche nell'editor mobile di TradingView senza errori.
// =============================================================================
indicator("RSI(2) Sequence 1-2-3 - Long/Short", overlay = true)

// ------------------------------ Inputs ---------------------------------------
rsiLen   = input.int(2, "RSI Length", minval = 1)
midLevel = input.float(50, "Mid Level")
srcRsi   = input.source(close, "RSI Source")

// --- Filtri ---
emaLen  = input.int(50, "EMA Length", minval = 1, group = "Filtri")
adxLen  = input.int(14, "ADX Length", minval = 1, group = "Filtri")
adxLow  = input.float(20, "ADX Lower Level", group = "Filtri")
adxHigh = input.float(40, "ADX Upper Level", group = "Filtri")

rsi = ta.rsi(srcRsi, rsiLen)

// Filtro EMA (trend + corpo candela) e filtro ADX (fuori dalla banda)
ema50 = ta.ema(close, emaLen)
bodyTop = math.max(open, close)
bodyBot = math.min(open, close)
emaBelowBody = ema50 < bodyBot   // EMA tutta sotto il corpo -> lato LONG
emaAboveBody = ema50 > bodyTop   // EMA tutta sopra il corpo -> lato SHORT
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)
adxOk = adx < adxLow or adx > adxHigh

crossUp   = ta.crossover(rsi, midLevel)
crossDown = ta.crossunder(rsi, midLevel)
noCross   = not crossUp and not crossDown

// -------- Estremi del segmento corrente sopra/sotto il livello 50 ------------
// lastTrough = minimo del dip appena concluso (origine del tratto rialzista)
// lastPeak   = massimo del rally appena concluso (origine del tratto ribassista)
var float segLow     = na
var float segHigh    = na
var float lastTrough = na
var float lastPeak   = na

prevLow  = segLow
prevHigh = segHigh

lastTrough := crossUp ? (na(prevLow) ? rsi : prevLow) : lastTrough
lastPeak   := crossDown ? (na(prevHigh) ? rsi : prevHigh) : lastPeak
segHigh    := crossUp ? rsi : segHigh
segLow     := crossDown ? rsi : segLow
segLow     := crossUp ? na : segLow
segHigh    := crossDown ? na : segHigh
segLow     := (noCross and rsi < midLevel) ? (na(segLow) ? rsi : math.min(segLow, rsi)) : segLow
segHigh    := (noCross and rsi > midLevel) ? (na(segHigh) ? rsi : math.max(segHigh, rsi)) : segHigh

// ============================ BUY 1-2-3 =====================================
// 0 idle | 1 tratto sopra 50 (forma il picco 1) | 2 pullback sotto 50 (punto 2)
// | 3 tratto sopra 50 in attesa della rottura del picco 1 (punto 3)
var int   buyPhase = 0
var float p1High   = na   // punto 1: massimo del primo tratto (resistenza)
var float startLow = na   // minimo del primo segnale (non deve essere rotto dal punto 2)
var float p2Low    = na   // punto 2: minimo del pullback

bph = buyPhase

startLow := (bph == 0 and crossUp) ? (na(lastTrough) ? rsi : lastTrough) : startLow
p1High   := (bph == 0 and crossUp) ? rsi : p1High
buyPhase := (bph == 0 and crossUp) ? 1 : buyPhase
p1High   := (bph == 1) ? math.max(p1High, rsi) : p1High
p2Low    := (bph == 1 and crossDown) ? rsi : p2Low
buyPhase := (bph == 1 and crossDown) ? 2 : buyPhase
p2Low    := (bph == 2) ? math.min(p2Low, rsi) : p2Low
buyPhase := (bph == 2 and p2Low < startLow) ? 0 : buyPhase
buyPhase := (bph == 2 and p2Low >= startLow and crossUp) ? 3 : buyPhase
buyPhase := (bph == 3 and crossDown) ? 0 : buyPhase

buyRaw = (bph == 3 and rsi > p1High) or (bph == 2 and p2Low >= startLow and crossUp and rsi > p1High)
buyPhase := buyRaw ? 0 : buyPhase

// ============================ SELL 1-2-3 ====================================
var int   sellPhase = 0
var float s1Low     = na   // punto 1: minimo del primo tratto (supporto)
var float startHigh = na   // massimo del primo segnale (non deve essere rotto dal punto 2)
var float s2High    = na   // punto 2: massimo del pullback

sph = sellPhase

startHigh := (sph == 0 and crossDown) ? (na(lastPeak) ? rsi : lastPeak) : startHigh
s1Low     := (sph == 0 and crossDown) ? rsi : s1Low
sellPhase := (sph == 0 and crossDown) ? 1 : sellPhase
s1Low     := (sph == 1) ? math.min(s1Low, rsi) : s1Low
s2High    := (sph == 1 and crossUp) ? rsi : s2High
sellPhase := (sph == 1 and crossUp) ? 2 : sellPhase
s2High    := (sph == 2) ? math.max(s2High, rsi) : s2High
sellPhase := (sph == 2 and s2High > startHigh) ? 0 : sellPhase
sellPhase := (sph == 2 and s2High <= startHigh and crossDown) ? 3 : sellPhase
sellPhase := (sph == 3 and crossUp) ? 0 : sellPhase

sellRaw = (sph == 3 and rsi < s1Low) or (sph == 2 and s2High <= startHigh and crossDown and rsi < s1Low)
sellPhase := sellRaw ? 0 : sellPhase

// ------------------------- Segnali filtrati ----------------------------------
// L'EMA deve stare tutta fuori dal corpo (sotto per LONG, sopra per SHORT):
// se tocca il corpo (tra open e close) niente segnale; le ombre possono essere toccate.
longOk  = buyRaw and emaBelowBody and adxOk
shortOk = sellRaw and emaAboveBody and adxOk

// ------------------------------- Plotting ------------------------------------
plot(ema50, title = "EMA", color = color.new(color.orange, 0))
plotshape(longOk, title = "LONG", style = shape.labelup, location = location.belowbar, color = color.new(color.green, 0), textcolor = color.white, text = "LONG", size = size.small)
plotshape(shortOk, title = "SHORT", style = shape.labeldown, location = location.abovebar, color = color.new(color.red, 0), textcolor = color.white, text = "SHORT", size = size.small)
barcolor(longOk ? color.new(color.green, 0) : shortOk ? color.new(color.red, 0) : na)

// -------------------------------- Alerts -------------------------------------
alertcondition(longOk, "RSI(2) 1-2-3 LONG", "RSI(2) 1-2-3 LONG signal")
alertcondition(shortOk, "RSI(2) 1-2-3 SHORT", "RSI(2) 1-2-3 SHORT signal")
