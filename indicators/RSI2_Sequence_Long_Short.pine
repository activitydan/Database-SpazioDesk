//@version=6
indicator("RSI(2) Sequence Long/Short", shorttitle="RSI2-Seq", overlay=true, max_labels_count=500)

// =====================================================================================
// RSI(2) SEQUENCE INDICATOR
// Replica la logica dell'EA MT5: sequenza a 3 segnali sull'RSI attorno al livello 50.
//
// LONG (specchiato per lo SHORT):
//   Segnale 1: RSI incrocia da sotto 50 a sopra 50   -> memorizza il minimo del tratto
//              sotto 50 appena concluso (Punto A)
//   Segnale 2: RSI ritorna sotto 50 SENZA rompere il Punto A (altrimenti sequenza
//              annullata) -> memorizza il massimo del primo tratto sopra 50 (Punto B)
//   Segnale 3: RSI ritorna sopra 50 e SUPERA il Punto B -> TRIGGER BUY
// =====================================================================================

// ------------------------------------ INPUT ------------------------------------------
grpRSI = "RSI"
rsiLen = input.int(2, "Periodo RSI", minval=1, group=grpRSI)
rsiSrc = input.source(close, "Sorgente RSI", group=grpRSI)

grpRisk = "Rischio / Stop (solo visualizzazione)"
rrRatio    = input.float(2.0, "Rischio/Rendimento (es. 2 = 1:2)", minval=0.1, step=0.1, group=grpRisk)
slBars     = input.int(20, "Candele in analisi per lo Stop Loss", minval=1, group=grpRisk)
slTicksBuf = input.int(20, "Tick aggiuntivi allo Stop Loss", minval=0, group=grpRisk)

grpSess = "Fascia oraria"
useSession = input.bool(true, "Attiva filtro fascia oraria", group=grpSess)
sessStart  = input.int(8,  "Ora inizio (0-23)", minval=0, maxval=23, group=grpSess)
sessEnd    = input.int(18, "Ora fine (0-23)",   minval=0, maxval=23, group=grpSess)

grpFilt = "Filtri segnale"
oneDirOnly = input.bool(true, "Non ripetere segnali nella stessa direzione (come EA)", group=grpFilt)

grpView = "Visualizzazione"
showSLTP = input.bool(true, "Mostra etichette SL/TP teorici sul segnale", group=grpView)

// ------------------------------------ RSI E CROSS ------------------------------------
rsi = ta.rsi(rsiSrc, rsiLen)

crossUp = ta.crossover(rsi, 50)
crossDn = ta.crossunder(rsi, 50)

// Tracciamento continuo degli estremi del tratto corrente sopra/sotto 50.
// Scritto come assegnazione a ternario per evitare qualsiasi if/else-if a inizio riga.
var float belowLow  = na   // minimo raggiunto nel tratto sotto 50 corrente
var float aboveHigh = na   // massimo raggiunto nel tratto sopra 50 corrente

belowLow  := crossDn ? rsi : (rsi < 50 ? (na(belowLow)  ? rsi : math.min(belowLow,  rsi)) : belowLow)
aboveHigh := crossUp ? rsi : (rsi > 50 ? (na(aboveHigh) ? rsi : math.max(aboveHigh, rsi)) : aboveHigh)

// ------------------------------- STATE MACHINE LONG ----------------------------------
// 0 = idle
// 1 = segnale 1 fatto  (RSI sopra 50, attende il ritorno sotto)
// 2 = segnale 2 fatto  (RSI sotto 50, deve tenere il Punto A, attende ritorno sopra)
// 3 = RSI di nuovo sopra 50, attende il superamento del Punto B
var int   longState  = 0
var float longPointA = na  // minimo del tratto sotto 50 pre-segnale1
var float longPointB = na  // massimo del primo tratto sopra 50

bool longSignal = false

if crossUp
    if longState == 0
        longPointA := belowLow
        longState  := 1
    else if longState == 2
        longState  := 3

if crossDn
    if longState == 1
        longPointB := aboveHigh
        longState  := 2
    else if longState == 3
        longState  := 0            // tornato sotto senza superare B -> sequenza fallita

// invalidazione: durante il pull-back rompe il minimo del segnale 1
if longState == 2 and not na(longPointA) and rsi < longPointA
    longState := 0

// trigger: supera il massimo della prima parte
if longState == 3 and not na(longPointB) and rsi > longPointB
    longSignal := true
    longState  := 0

// ------------------------------- STATE MACHINE SHORT (specchiata) --------------------
var int   shortState  = 0
var float shortPointA = na  // massimo del tratto sopra 50 pre-segnale1
var float shortPointB = na  // minimo del primo tratto sotto 50

bool shortSignal = false

if crossDn
    if shortState == 0
        shortPointA := aboveHigh
        shortState  := 1
    else if shortState == 2
        shortState  := 3

if crossUp
    if shortState == 1
        shortPointB := belowLow
        shortState  := 2
    else if shortState == 3
        shortState  := 0

if shortState == 2 and not na(shortPointA) and rsi > shortPointA
    shortState := 0

if shortState == 3 and not na(shortPointB) and rsi < shortPointB
    shortSignal := true
    shortState  := 0

// ------------------------------- FILTRO FASCIA ORARIA --------------------------------
inSession = not useSession or (hour >= sessStart and hour < sessEnd)

// ------------------ FILTRO "NON RI-SEGNALARE NELLA STESSA DIREZIONE" ------------------
var int lastSignalDir = 0   // 1 = ultimo segnale long, -1 = ultimo segnale short

bool finalLong  = false
bool finalShort = false

if longSignal and inSession and (not oneDirOnly or lastSignalDir != 1)
    finalLong := true
    lastSignalDir := 1

if shortSignal and inSession and (not oneDirOnly or lastSignalDir != -1)
    finalShort := true
    lastSignalDir := -1

// --------------------------------- SL / TP TEORICI -----------------------------------
tick = syminfo.mintick

longSL   = ta.lowest(low, slBars) - slTicksBuf * tick
longRisk = close - longSL
longTP   = close + longRisk * rrRatio

shortSL   = ta.highest(high, slBars) + slTicksBuf * tick
shortRisk = shortSL - close
shortTP   = close - shortRisk * rrRatio

// --------------------------------- PLOT SEGNALI --------------------------------------
plotshape(finalLong,  title="BUY",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="BUY")
plotshape(finalShort, title="SELL", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,  0), size=size.small, text="SELL")

if finalLong and showSLTP
    label.new(bar_index, low, "BUY\nSL " + str.tostring(longSL, format.mintick) + "\nTP " + str.tostring(longTP, format.mintick), style=label.style_label_up, color=color.new(color.lime, 70), textcolor=color.black, size=size.small)

if finalShort and showSLTP
    label.new(bar_index, high, "SELL\nSL " + str.tostring(shortSL, format.mintick) + "\nTP " + str.tostring(shortTP, format.mintick), style=label.style_label_down, color=color.new(color.red, 70), textcolor=color.black, size=size.small)

// ------------------------------------ ALERT ------------------------------------------
alertcondition(finalLong,  title="RSI2 Sequence BUY",  message="RSI2 Sequence: segnale BUY")
alertcondition(finalShort, title="RSI2 Sequence SELL", message="RSI2 Sequence: segnale SELL")
